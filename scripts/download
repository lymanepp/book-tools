#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../.." && pwd)"
OUT_DIR="artifacts"

artifact_name="${1:-}"

# Resolve from repo.yml if not provided
if [[ -z "$artifact_name" ]]; then
  if [[ -f "${REPO_ROOT}/repo.yml" ]]; then
    artifact_name="$(grep -E '^artifact_basename:' "${REPO_ROOT}/repo.yml" | awk '{print $2}')"
  fi
fi

# Final validation
if [[ -z "${artifact_name:-}" ]]; then
  echo "ERROR: Artifact name not provided and not found in repo.yml" >&2
  echo "Usage: $0 <artifact-name>" >&2
  exit 1
fi

rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

echo "Downloading artifact: $artifact_name"

gh run download --name "$artifact_name" --dir "$OUT_DIR"

# Flatten directory structure
find "$OUT_DIR" -type f -name "*.pdf" -exec mv -t "$OUT_DIR" {} +
find "$OUT_DIR" -type f -name "*.docx" -exec mv -t "$OUT_DIR" {} +
find "$OUT_DIR" -mindepth 1 -type d -empty -delete

# Convert to PDF
shopt -s nullglob
for docx in "$OUT_DIR"/*.docx; do
  echo "Converting: $docx"
  bash "$SCRIPT_DIR/docx2pdf.sh" "$docx"
done
shopt -u nullglob

echo "Done. Files in $OUT_DIR:"
ls -1 "$OUT_DIR"
