#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
OUT="$ROOT/artifacts"
TMP="$OUT/.download"

repo_value() {
  awk -F: -v key="$1" '$1 == key {
    sub(/^[^:]*:[[:space:]]*/, "")
    gsub(/^[[:space:]\047\042]+|[[:space:]\047\042]+$/, "")
    print; exit
  }' "$ROOT/repo.yml"
}

BASE="$(repo_value artifact_basename)"
TARGETS="$(repo_value artifact_targets)"
[[ -n "$BASE" ]] || { echo "ERROR: repo.yml must define artifact_basename." >&2; exit 1; }

case "${1:-}" in
  "") read -ra requested <<<"${TARGETS:-}" ;;
  "$BASE"-*) requested=("${1#"$BASE"-}") ;;
  *) requested=("$1") ;;
esac
((${#requested[@]})) || requested=("")

latest_artifact_id() {
  local target="$1" stable="${BASE}${target:+-$target}" id
  id="$(gh api "repos/{owner}/{repo}/actions/artifacts?name=$stable&per_page=100" \
    --jq '[.artifacts[] | select(.expired == false)] | sort_by(.created_at) | last | .id // empty')"
  if [[ -z "$id" && -n "$target" ]]; then
    [[ "$target" =~ ^[A-Za-z0-9._-]+$ ]] || { echo "ERROR: Invalid artifact target: $target" >&2; exit 2; }
    id="$(gh api 'repos/{owner}/{repo}/actions/artifacts?per_page=100' \
      --jq "[.artifacts[] | select(.expired == false and (.name | startswith(\"$target-\")))] | sort_by(.created_at) | last | .id // empty")"
  fi
  printf '%s\n' "$id"
}

rm -rf "$OUT"
mkdir -p "$TMP"

for target in "${requested[@]}"; do
  stable="${BASE}${target:+-$target}"
  id="$(latest_artifact_id "$target")"
  [[ -n "$id" ]] || { echo "ERROR: No unexpired artifact found for '${target:-$BASE}'." >&2; exit 1; }

  echo "Downloading: $stable"
  dir="$TMP/$stable"
  mkdir -p "$dir"
  gh api "repos/{owner}/{repo}/actions/artifacts/$id/zip" > "$dir.zip"
  unzip -q "$dir.zip" -d "$dir"
done

while IFS= read -r -d '' file; do
  dest="$OUT/$(basename "$file")"
  [[ ! -e "$dest" ]] || { echo "ERROR: Duplicate artifact file: $(basename "$file")" >&2; exit 1; }
  mv "$file" "$dest"
done < <(find "$TMP" -type f ! -name '*.zip' -print0)
rm -rf "$TMP"

shopt -s nullglob
for sums in "$OUT"/*SHA256SUMS; do
  (cd "$OUT" && sha256sum --check "$(basename "$sums")")
done

echo "Downloaded to $OUT:"
find "$OUT" -maxdepth 1 -type f -printf '%f\n' | sort
